{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "arsam.net section",
  "type": "object",
  "required": [
    "id",
    "kind",
    "order",
    "slug",
    "title",
    "blocks",
    "refs"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "section"
    },
    "schemaVersion": {
      "type": "string"
    },
    "lang": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "minimum": 1
    },
    "slug": {
      "type": "string"
    },
    "nav": {
      "type": "object",
      "required": [
        "num",
        "label"
      ]
    },
    "background": {
      "type": "string"
    },
    "title": {
      "type": "object",
      "required": [
        "text"
      ]
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type"
        ]
      }
    },
    "refs": {
      "type": "object",
      "properties": {
        "metrics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}